# Front-end runtime config (Next.js)

# Spring API base URL (local)
NEXT_PUBLIC_API_BASE_URL=https://giga-interior-1tqs.vercel.app/

# Admin localStorage key (can be changed for namespace separation)
NEXT_PUBLIC_ADMIN_AUTH_STORAGE_KEY=giga.admin.auth

# Temporary mock admin login (development only; disable in production)
NEXT_PUBLIC_ENABLE_MOCK_ADMIN_LOGIN=false


