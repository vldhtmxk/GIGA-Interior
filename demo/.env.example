# Docker Compose / Spring local development defaults

# MySQL container
MYSQL_IMAGE=mysql:8.4
MYSQL_PORT=3306
MYSQL_DATABASE=giga
MYSQL_USER=giga
MYSQL_PASSWORD=giga2024!
MYSQL_ROOT_PASSWORD=root1234!
TZ=Asia/Seoul

# Spring Boot
SPRING_APP_NAME=demo
SPRING_DOCKER_COMPOSE_ENABLED=false
SERVER_PORT=8080
DB_URL=jdbc:mysql://localhost:3306/giga?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=Asia/Seoul&characterEncoding=UTF-8
DB_USERNAME=giga
DB_PASSWORD=giga2024!
JPA_DDL_AUTO=validate
JPA_SHOW_SQL=true
JPA_FORMAT_SQL=true
APP_CORS_ALLOWED_ORIGINS=http://localhost:3000
APP_UPLOAD_DIR=uploads

# AWS (future)
APP_AWS_S3_ENABLED=false
AWS_REGION=ap-northeast-2
AWS_S3_BUCKET=
AWS_CLOUDFRONT_DOMAIN=

# Notifications (optional)
APP_NOTIFY_SLACK_ENABLED=false
APP_NOTIFY_SLACK_WEBHOOK_URL=
APP_NOTIFY_EMAIL_ENABLED=false
APP_NOTIFY_EMAIL_TO=

# SMTP (local default example: MailHog/Mailpit)
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_SMTP_AUTH=false
MAIL_SMTP_STARTTLS_ENABLE=false
MAIL_SMTP_STARTTLS_REQUIRED=false
MAIL_SMTP_CONNECTION_TIMEOUT=5000
MAIL_SMTP_TIMEOUT=5000
MAIL_SMTP_WRITE_TIMEOUT=5000
