{
  "name": "pdf-workbench-electron",
  "version": "0.1.0",
  "description": "PDF split/merge desktop app (Electron)",
  "main": "main.js",
  "author": "Codex",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "dependencies": {
    "jszip": "^3.10.1",
    "pdf-lib": "^1.17.1"
  },
  "devDependencies": {
    "electron": "^36.3.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.giga.pdfworkbench",
    "productName": "PDF Workbench",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    }
  }
}
